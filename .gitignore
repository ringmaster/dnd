# Generated sheets — built by `node src/build.mjs` (locally or in CI), never committed.
# GitHub Pages is published from the build artifact by .github/workflows/pages.yml.
/docs/

# npm — only the OG-image generator needs deps; the core build stays zero-dependency
/node_modules/

# macOS
.DS_Store

# Scraper raw response cache (src/builder/scrape.mjs) — enriched output is committed
/.cache/

# Editor cruft
*.swp
*~
.vscode/
.idea/
