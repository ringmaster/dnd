  "ref": {
    "battleaxe": {
      "title": "Battleaxe (Moon-Touched)",
      "dice": "To hit: d20 +6   ·   Damage: 1d8 +4",
      "chips": [
        {
          "t": "Slashing"
        },
        {
          "t": "Versatile 1d10"
        },
        {
          "t": "Crit 2d8+4",
          "c": "ember"
        },
        {
          "t": "Topple",
          "c": "storm"
        },
        {
          "t": "Magical",
          "c": "storm"
        }
      ],
      "body": [
        "One attack on your turn (Extra Attack arrives at level 5). Use two-handed for 1d10+4 when you drop the shield.",
        "Topple (mastery): on a hit, the target makes a Constitution save (DC 14) or has the Prone condition.",
        "Moon-Touched: a magic weapon, so your attacks with it count as magical — they bypass resistance and immunity to nonmagical damage. While drawn in darkness it sheds Bright Light (15 ft) and Dim Light for another 15 ft. It grants no bonus to attack or damage rolls."
      ]
    },
    "moontouched": {
      "title": "Moon-Touched Battleaxe",
      "dice": null,
      "chips": [
        {
          "t": "Common"
        },
        {
          "t": "No attunement",
          "c": "storm"
        },
        {
          "t": "Magic weapon",
          "c": "storm"
        },
        {
          "t": "Sheds light",
          "c": "ember"
        }
      ],
      "body": [
        "A common magic battleaxe. While it is drawn in darkness, the blade sheds Bright Light in a 15-foot radius and Dim Light for an additional 15 feet.",
        "Because it is a magic weapon, attacks made with it count as magical and overcome resistance or immunity to damage from nonmagical attacks. It grants no bonus to attack or damage rolls.",
        "This is the weapon you wield, carrying the Topple mastery."
      ]
    },
    "handaxe": {
      "title": "Handaxe",
      "dice": "To hit: d20 +6   ·   Damage: 1d6 +4",
      "chips": [
        {
          "t": "Thrown 20/60"
        },
        {
          "t": "Light"
        },
        {
          "t": "Crit 2d6+4",
          "c": "ember"
        },
        {
          "t": "Vex",
          "c": "storm"
        }
      ],
      "body": [
        "A reliable thrown option when melee isn't possible.",
        "Vex (mastery): when you hit and deal damage, you have Advantage on your next attack roll against that target, lasting until the end of your next turn."
      ]
    },
    "combatsup": {
      "title": "Combat Superiority",
      "dice": "4 superiority dice (d8)",
      "chips": [
        {
          "t": "Maneuver DC 14",
          "c": "ember"
        },
        {
          "t": "Short or long rest",
          "c": "storm"
        }
      ],
      "body": [
        "You have four d8 superiority dice. You spend them to fuel maneuvers, and regain all of them on a short or long rest.",
        "Maneuver save DC = 8 + proficiency + Strength = 14."
      ]
    },
    "trip": {
      "title": "Trip Attack",
      "dice": "1d8  (spend a superiority die)",
      "pool": "sup",
      "chips": [
        {
          "t": "On a hit"
        },
        {
          "t": "Str save DC 14",
          "c": "storm"
        }
      ],
      "body": [
        "When you hit, add the superiority die to the damage. The target then makes a Strength save (DC 14) or falls Prone.",
        "Prone gives melee attackers advantage and ranged attackers disadvantage against the target."
      ]
    },
    "goad": {
      "title": "Goading Attack",
      "dice": "1d8  (spend a superiority die)",
      "pool": "sup",
      "chips": [
        {
          "t": "On a hit"
        },
        {
          "t": "Wis save DC 14",
          "c": "storm"
        }
      ],
      "body": [
        "When you hit, add the superiority die to the damage. On a failed Wisdom save (DC 14), the target has Disadvantage on attacks against anyone other than you until the end of your next turn.",
        "This is your bodyguard button: pull the dangerous enemy onto your high AC."
      ]
    },
    "precision": {
      "title": "Precision Attack",
      "dice": "1d8  (spend a superiority die)",
      "pool": "sup",
      "chips": [
        {
          "t": "To the attack roll",
          "c": "ember"
        }
      ],
      "body": [
        "Add the superiority die to an attack roll. You may use this after you roll the d20 but before the hit or miss is decided.",
        "Your insurance on a swing that has to land."
      ]
    },
    "secondwind": {
      "title": "Second Wind",
      "dice": "1d10 +4 healing",
      "pool": "sw",
      "chips": [
        {
          "t": "Bonus action"
        },
        {
          "t": "3 uses"
        },
        {
          "t": "Short or long rest",
          "c": "storm"
        }
      ],
      "body": [
        "As a Bonus Action, regain 1d10+4 hit points (1d10 + your fighter level). Three uses; regain them on a short or long rest.",
        "Tap Use below to spend a charge, then roll your d10 and apply it with the Heal control."
      ]
    },
    "actionsurge": {
      "title": "Action Surge",
      "dice": null,
      "pool": "as",
      "chips": [
        {
          "t": "1 use"
        },
        {
          "t": "Short or long rest",
          "c": "storm"
        }
      ],
      "body": [
        "Once per short or long rest, take one additional action on your turn. At level 4 that most often means a second Attack action — your burst round."
      ]
    },
    "tacticalmind": {
      "title": "Tactical Mind",
      "dice": "+1d10 to a failed check",
      "chips": [
        {
          "t": "Uses Second Wind",
          "c": "ember"
        }
      ],
      "body": [
        "When you fail an ability check, you can expend a use of Second Wind to add 1d10 to the check, potentially turning failure into success.",
        "If it still fails, you don't lose the Second Wind use."
      ]
    },
    "asi": {
      "title": "Level 4 — Ability Score Improvement",
      "dice": null,
      "chips": [
        {
          "t": "+2 Strength",
          "c": "ember"
        }
      ],
      "body": [
        "You raised Strength from 16 to 18 (+4). That improved your attack and damage bonuses, maneuver save DC, Athletics, and Strength saves."
      ]
    },
    "fightingstyle": {
      "title": "Fighting Style: Defense",
      "dice": null,
      "chips": [
        {
          "t": "+1 AC",
          "c": "ember"
        }
      ],
      "body": [
        "While you are wearing armor, you gain a +1 bonus to AC. Already included in your AC of 19 (chain mail 16 + shield 2 + 1)."
      ]
    },
    "studentofwar": {
      "title": "Student of War",
      "dice": null,
      "chips": [
        {
          "t": "Skill"
        },
        {
          "t": "Smith's tools"
        }
      ],
      "body": [
        "You gain proficiency with one type of artisan's tools (Smith's tools fits the name) and one skill from the fighter list."
      ]
    }
  },
