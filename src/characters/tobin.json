      "body": [
        "Vestacia's domain of life and renewal. You always have Bless, Cure Wounds, Aid, and Lesser Restoration prepared, gain the Preserve Life Channel Divinity option, and your healing spells restore extra hit points (Disciple of Life)."
      ]
    },
    "discipleoflife": {
      "title": "Disciple of Life",
      "dice": "+ (2 + spell level) HP",
      "chips": [
        {
          "t": "On a healing spell",
          "c": "ember"
        }
      ],
      "body": [
        "Whenever you restore hit points to a creature with a level 1+ spell, on the turn you cast it the creature regains additional hit points equal to 2 + the spell's level."
      ]
    },
    "channeldivinity": {
      "title": "Channel Divinity",
      "dice": null,
      "pool": "cd",
      "chips": [
        {
          "t": "2 uses",
          "c": "ember"
        },
        {
          "t": "Short or long rest",
          "c": "storm"
        }
      ],
      "body": [
        "A Magic action that fuels one of your divine options — [[divinespark|Divine Spark]], [[turnundead|Turn Undead]], or [[preservelife|Preserve Life]]. You have two uses; regain one on a short rest and all on a long rest.",
        "Tap an option above to see how it works, then tap Use here to spend a use."
      ]
    },
    "divinespark": {
      "title": "Divine Spark",
      "dice": "1d8 + Wis (+4)",
      "chips": [
        {
          "t": "Channel Divinity",
          "c": "ember"
        },
        {
          "t": "30 ft"
        }
      ],
      "body": [
        "Point your holy symbol at a creature within 30 ft and roll 1d8 + Wis. Either heal it that much, or force a Constitution save for Radiant or Necrotic damage (half on a success). Costs a Channel Divinity use."
      ]
    },
    "turnundead": {
      "title": "Turn Undead",
      "dice": "Wis save DC 14",
      "chips": [
        {
          "t": "Channel Divinity",
          "c": "ember"
        },
        {
          "t": "30 ft"
        }
      ],
      "body": [
        "Each Undead of your choice within 30 ft makes a Wisdom save or is Frightened and Incapacitated for 1 minute, fleeing from you. Costs a Channel Divinity use."
      ]
    },
    "preservelife": {
      "title": "Preserve Life",
      "dice": "heal 5 × level (20)",
      "chips": [
        {
          "t": "Channel Divinity",
          "c": "ember"
        },
        {
          "t": "Life Domain"
        }
      ],
      "body": [
        "Restore hit points equal to five times your cleric level (20 at level 4), divided among Bloodied creatures within 30 ft (can include you). It can't raise a creature above half its hit point maximum. Costs a Channel Divinity use."
      ]
    },
    "divineorder": {
      "title": "Divine Order: Protector",
      "dice": null,
      "chips": [
        {
          "t": "Martial weapons",
          "c": "storm"
