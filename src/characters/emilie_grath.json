    {
      "type": "background",
      "hint": "Half-Elf · Haunted One · Chaotic Good",
      "paras": [
        "Emilie Grath is a 20-year-old half-elf sorcerer in Port Haven, Azuria — slim and otherworldly, with long jet-black hair, bright green eyes that glint with a hint of madness, and delicate features. She wears a simple black robe she embroidered with glyphs she found pretty in old books.",
        "Raised in an orphanage alongside her friends Wex and Royce, she never learned what became of her parents; the question was always deflected. Self-taught after showing early talent, she takes odd jobs to buy books and spell components and rents a small room above a shop.",
        "She wants to join the Magician's Coven and the Order of the Quartz Tower, and quietly studies the wizard Oronos Silvermane — copying his walk, his gestures, anything. Without a mentor, mimicry has become her way of learning.",
        "<b>Bond:</b> I keep my thoughts and discoveries in a journal — my journal is my legacy. <b>Flaw:</b> I talk to spirits that no one else can see."
      ]
    }
  ],
  "ref": {
    "etherealdagger": {
      "title": "Ethereal Dagger",
      "chips": [
        {
          "t": "Finesse · 1d4 piercing"
        },
        {
          "t": "Nick · Thrown 20/60"
        },
        {
          "t": "Magical",
          "c": "ember"
        }
      ],
      "body": [
        "A crystallized shard of the ethereal plane. +10 to hit (Dex +3, proficiency +6, magic +1); 1d4 + 4 piercing. Finesse, light, and thrown (20/60).",
        "Nick (mastery): the extra Light-weapon attack rides your Attack action rather than your Bonus Action."
      ]
    },
    "glassweaversstaff": {
      "title": "Glassweaver's Staff",
      "chips": [
        {
          "t": "Versatile · 1d6 bludgeoning"
        },
        {
          "t": "Topple",
          "c": "storm"
        },
        {
          "t": "Arcane focus"
        }
      ],
      "body": [
        "A spun-glass quarterstaff that doubles as her arcane focus. Versatile (1d8 in two hands).",
        "Topple (mastery): on a hit, force a Constitution save or knock the target Prone."
      ]
    },
    "sorcery-spellcasting": {
      "title": "Spellcasting",
      "chips": [
        {
          "t": "Charisma",
          "c": "storm"
        },
        {
          "t": "DC 18 · atk +10"
        }
      ],
      "body": [
        "You cast Sorcerer spells using Charisma: spell save DC 18, spell attack +10. As an 18th-level sorcerer you have slots up to 9th level and a wide list of known spells; cantrips are at will."
      ]
    },
    "aberrantmind": {
      "title": "Sorcerous Origin: Aberrant Mind",
      "chips": [
        {
          "t": "Psionic",
          "c": "ember"
        }
      ],
      "body": [
        "A psychic awakening — perhaps from an aberration, the Far Realm, or a strange dream — left alien power coiled in your mind. It grants always-prepared Psionic Spells and a growing suite of telepathic and reality-warping gifts."
      ]
    },
    "psionicspells": {
      "title": "Psionic Spells",
      "chips": [
        {
          "t": "Always prepared",
          "c": "storm"
        }
      ],
      "body": [
        "You always have a set of Psionic Spells prepared (they don't count against any limit): Arms of Hadar, Dissonant Whispers, Calm Emotions, Detect Thoughts, Hunger of Hadar, Sending, Evard's Black Tentacles, Summon Aberration, Rary's Telepathic Bond, and Telekinesis. With Psychic Sorcery you can cast them by spending sorcery points instead of slots."
      ]
    },
    "telepathicspeech": {
      "title": "Telepathic Speech",
      "body": [
        "As a Bonus Action, choose one creature within 30 ft; for 18 minutes you can speak telepathically to each other while within 4 miles."
      ]
    },
    "psychicsorcery": {
      "title": "Psychic Sorcery",
      "chips": [
        {
          "t": "Sorcery Points",
          "c": "ember"
        }
      ],
      "body": [
        "When you cast a Psionic Spell, you can spend sorcery points (equal to its level) instead of a slot. Cast this way it needs no verbal, somatic, or non-consumed material components — entirely in your mind."
      ]
    },
    "psychicdefenses": {
      "title": "Psychic Defenses",
      "chips": [
        {
          "t": "Resist psychic",
          "c": "storm"
        }
      ],
      "body": [
        "You have Resistance to psychic damage and Advantage on saving throws to avoid or end the Charmed and Frightened conditions."
      ]
    },
    "warpingimplosion": {
      "title": "Warping Implosion",
      "pool": "warp",
      "chips": [
        {
          "t": "Teleport 120 ft",
          "c": "ember"
        },
        {
          "t": "1/long rest"
        }
      ],
      "body": [
        "As an Action, teleport to an unoccupied space within 120 ft. Each creature within 30 ft of the space you left makes a Strength save (DC 18): 3d10 force and pulled toward your old space on a fail (half, no pull, on success). Recharge by finishing a long rest or spending 5 sorcery points."
      ]
    },
    "revelationinflesh": {
      "title": "Revelation in Flesh",
      "chips": [
        {
          "t": "Bonus action",
          "c": "ember"
        }
      ],
      "body": [
        "As a Bonus Action, spend 1+ sorcery points to transform your body for 10 minutes, gaining one benefit per point: see invisible creatures (120 ft), a swim speed and water breathing, a fly speed, or squeeze through tiny gaps as if Tiny."
      ]
    },
    "fontofmagic": {
      "title": "Font of Magic",
      "pool": "sp",
      "chips": [
        {
          "t": "18 Sorcery Points",
          "c": "ember"
        }
      ],
      "body": [
        "You have 18 Sorcery Points, regained on a long rest. As a Bonus Action, convert sorcery points into spell slots or spell slots into sorcery points, and fuel Metamagic."
      ]
    },
    "metamagic": {
      "title": "Metamagic",
      "chips": [
        {
          "t": "Distant"
        },
        {
          "t": "Subtle"
        },
        {
          "t": "Twinned"
        }
      ],
      "body": [
        "Distant Spell (1 SP): double a spell's range (or reach 30 ft for touch). Subtle Spell (1 SP): cast without verbal or somatic components. Twinned Spell (SP = level): a single-target spell targets a second creature."
      ]
    },
    "magicinitiate": {
      "title": "Magic Initiate (Sorcerer)",
      "chips": [
        {
          "t": "Origin feat",
          "c": "ember"
        }
      ],
      "body": [
        "You know the cantrips Blade Ward and Fire Bolt, and the 1st-level spell Feather Fall, castable once per long rest without a slot (or with one). Charisma is the spellcasting ability."
      ]
    },
    "feytouched": {
      "title": "Fey Touched",
      "chips": [
        {
          "t": "+1 Cha",
          "c": "ember"
        }
      ],
      "body": [
        "Your Charisma increased by 1. You always have Misty Step and Silvery Barbs prepared and can cast each once per long rest without a slot (or with one), using Charisma."
      ]
    },
    "feyancestry": {
      "title": "Fey Ancestry",
      "chips": [
        {
          "t": "vs Charm",
          "c": "storm"
        }
      ],
      "body": [
        "You have Advantage on saving throws against being Charmed, and magic can't put you to sleep."
      ]
    },
    "skillversatility": {
      "title": "Skill Versatility & Darkvision",
      "chips": [
        {
          "t": "Darkvision 60 ft",
          "c": "storm"
        }
      ],
      "body": [
        "You gain proficiency in two skills of your choice (Insight and Intimidation), and you can see in dim light within 60 ft as if it were bright light, and in darkness as if dim light."
      ]
    }
  },
