    {
      "type": "buildlog",
      "title": "Build Log",
      "hint": "every choice, level by level",
      "levels": [
        {
          "title": "Level 1",
          "tag": "Fighter",
          "items": [
            {
              "html": "<b>Fighting Style</b> — You gain a Fighting Style feat of your choice (Defense, Dueling, Archery, Great Weapon Fighting, etc.) — record it on your sheet."
            },
            {
              "html": "<b>Second Wind</b> — As a Bonus Action, regain 1d10 + your fighter level hit points. Regain your uses on a short or long rest."
            },
            {
              "html": "<b>Weapon Mastery</b> — You can use the mastery property of three kinds of weapons of your choice; change the choices after a long rest. Pick them in the Weapon Mastery panel."
            },
            {
              "html": "<b>Species: Human</b> — Skillful, Resourceful, Versatile · Speed 30"
            },
            {
              "html": "<b>Ability scores:</b> Str 17, Dex 13, Con 14, Int 12, Wis 11, Cha 8 <span class=\"tag\">(background +2 STR / +1 WIS)</span>"
            },
            {
              "cls": "choice",
              "html": "<b>Background: Guard</b> — Origin feat Alert"
            },
            {
              "cls": "choice",
              "html": "<b>Skills (Fighter, choose 2):</b> Athletics, Perception"
            },
            {
              "cls": "choice",
              "html": "<b>Fighting Style:</b> Defense"
            }
          ]
        },
        {
          "title": "Level 2",
          "tag": "Fighter",
          "items": [
            {
              "html": "<b>Action Surge</b> — On your turn, take one additional action — most often a second Attack action. Regain it on a short or long rest."
            },
            {
              "html": "<b>Tactical Mind</b> — When you fail an ability check, you can expend a use of Second Wind to add 1d10 to the check. If it still fails, you don't lose the Second Wind use."
            }
          ]
        },
        {
          "title": "Level 3",
          "tag": "Fighter",
          "items": [
            {
              "cls": "choice",
              "html": "<b>Subclass:</b> Eldritch Knight"
            },
            {
              "html": "<b>Spellcasting</b> — You learn wizard spells, using Intelligence as your spellcasting ability. At level 3 you know two cantrips and three 1st-level spells, mostly from the Abjuration and Evocation schools."
            },
            {
              "html": "<b>War Bond</b> — You can bond with up to two weapons over a 1-hour ritual during a Short or Long Rest; you can bond with only two at a time and a third bond breaks the oldest."
            }
          ]
        },
        {
          "title": "Level 4",
          "tag": "Fighter",
          "items": [
            {
              "cls": "choice",
              "html": "<b>Feat:</b> Alert"
            }
          ]
        }
      ]
    }
