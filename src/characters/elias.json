  "ref": {
    "asi": {
      "title": "Level 4 — Ability Score Improvement",
      "dice": null,
      "chips": [
        {
          "t": "+2 Intelligence",
          "c": "ember"
        }
      ],
      "body": [
        "You raised Intelligence from 17 to 19 (+4). That improved your spell save DC, spell attack, Arcana/History/Investigation, and Int saves.",
        "A feat was the alternative; you also still have the Human Versatile Origin feat to place."
      ]
    },
    "portent": {
      "title": "Portent",
      "dice": "2 dice, after a long rest",
      "pool": "portent",
      "chips": [
        {
          "t": "Roll 2 d20",
          "c": "ember"
        },
        {
          "t": "Replace any d20",
          "c": "storm"
        },
        {
          "t": "Long rest"
        }
      ],
      "body": [
        "When you finish a long rest, roll two d20s and record the numbers. You can replace any attack roll, saving throw, or ability check — made by you or a creature you can see — with one of these rolls (before the roll is made). Each recorded roll is used once.",
        "Write the two values somewhere; tap Use to mark one spent."
      ]
    },
    "diviner": {
      "title": "Divination Savant",
      "dice": null,
      "chips": [
        {
          "t": "Half cost & time",
          "c": "storm"
        }
      ],
      "body": [
        "When you copy a Divination spell into your spellbook, it takes half the usual gold and time. You also gained Portent at this level."
      ]
    },
    "scholar": {
      "title": "Scholar",
      "dice": null,
      "chips": [
        {
          "t": "Expertise: Arcana",
          "c": "ember"
        }
      ],
      "body": [
        "You gain Expertise in one Intelligence-based skill — taken in Arcana, doubling your Proficiency Bonus there (Arcana +6)."
      ]
    },
    "arcanerecovery": {
      "title": "Arcane Recovery",
      "dice": null,
      "pool": "arcrec",
      "chips": [
        {
          "t": "On a short rest",
          "c": "storm"
        },
        {
          "t": "1/day",
          "c": "ember"
        }
      ],
      "body": [
        "Once per day, when you finish a short rest, you can recover expended spell slots whose levels total no more than half your wizard level rounded up (2 at level 4), none of 6th level or higher.",
        "Tap Use to mark it spent; it returns on a long rest."
      ]
    },
    "ritualadept": {
      "title": "Ritual Adept",
      "dice": null,
      "chips": [
        {
          "t": "Ritual casting",
          "c": "storm"
        }
      ],
      "body": [
        "You can cast any spell with the Ritual tag as a ritual if it's in your spellbook, without preparing it — it just takes 10 minutes longer and uses no slot."
      ]
    },
    "quarterstaff": {
