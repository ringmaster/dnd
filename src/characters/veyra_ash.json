    {
      "type": "buildlog",
      "title": "Build Log",
      "hint": "every choice, level by level",
      "levels": [
        {
          "title": "Level 1",
          "tag": "Fighter",
          "items": [
            {
              "html": "<b>Fighting Style</b> — You gain a Fighting Style feat of your choice (Defense, Dueling, Archery, Great Weapon Fighting, etc.) — record it on your sheet."
            },
            {
              "html": "<b>Second Wind</b> — As a Bonus Action, regain 1d10 + your fighter level hit points. Regain your uses on a short or long rest."
            },
            {
              "html": "<b>Weapon Mastery</b> — You can use the mastery property of three kinds of weapons of your choice; change the choices after a long rest. Pick them in the Weapon Mastery panel."
            },
            {
              "html": "<b>Species: Tiefling</b> — Darkvision, Otherworldly Presence · Speed 30"
            },
            {
              "html": "<b>Ability scores:</b> Str 17, Dex 13, Con 15, Int 8, Wis 10, Cha 12 <span class=\"tag\">(background +2 STR / +1 CON)</span>"
            },
            {
              "cls": "choice",
              "html": "<b>Background: Soldier</b> — Origin feat Savage Attacker"
            },
            {
              "cls": "choice",
              "html": "<b>Skills (Fighter, choose 2):</b> Perception, Survival"
            },
            {
              "cls": "choice",
              "html": "<b>Fighting Style:</b> Defense"
            }
          ]
        },
        {
          "title": "Level 2",
          "tag": "Fighter",
          "items": [
            {
              "html": "<b>Action Surge</b> — On your turn, take one additional action — most often a second Attack action. Regain it on a short or long rest."
            },
            {
              "html": "<b>Tactical Mind</b> — When you fail an ability check, you can expend a use of Second Wind to add 1d10 to the check. If it still fails, you don't lose the Second Wind use."
            }
          ]
        },
        {
          "title": "Level 3",
          "tag": "Fighter",
          "items": [
            {
              "cls": "choice",
              "html": "<b>Subclass:</b> Champion"
            },
            {
              "html": "<b>Improved Critical</b> — Your attack rolls with weapons and Unarmed Strikes can score a critical hit on a roll of 19 or 20."
            },
            {
              "html": "<b>Remarkable Athlete</b> — You have Advantage on Initiative rolls and Strength (Athletics) checks. Once per turn, immediately after a Strength-based attack that hits, you can move up to half your Speed without provoking Opportunity Attacks."
            }
          ]
        },
        {
          "title": "Level 4",
          "tag": "Fighter",
          "items": [
            {
              "cls": "choice",
              "html": "<b>Ability Score Improvement:</b> +2 STR"
            }
          ]
        },
        {
          "title": "Level 5",
          "tag": "Fighter",
          "items": [
            {
              "html": "<b>Extra Attack</b> — You can attack twice, instead of once, whenever you take the Attack action on your turn."
            },
            {
              "html": "<b>Tactical Shift</b> — Whenever you activate Second Wind, you can move up to half your Speed without provoking Opportunity Attacks."
            }
          ]
        }
      ]
    }
  ],
