  "ref": {
    "longbow": {
      "title": "Longbow",
      "dice": "To hit: d20 +8   ·   Damage: 1d8 +4",
      "chips": [
        {
          "t": "Piercing"
        },
        {
          "t": "Range 150/600"
        },
        {
          "t": "Two-handed"
        },
        {
          "t": "Crit 2d8+4",
          "c": "ember"
        },
        {
          "t": "Slow",
          "c": "storm"
        }
      ],
      "body": [
        "One attack on your turn (Extra Attack arrives at level 5). +7 to hit = Dex +3, proficiency +2, and the Archery fighting style +2. Damage adds your Dexterity (+3).",
        "Slow (mastery): when you hit and deal damage, the target's Speed drops by 10 feet until the start of your next turn.",
        "Needs ammunition and two free hands to fire."
      ]
    },
    "shortsword": {
      "title": "Shortsword",
      "dice": "To hit: d20 +6   ·   Damage: 1d6 +4",
      "chips": [
        {
          "t": "Piercing"
        },
        {
          "t": "Finesse"
        },
        {
          "t": "Light"
        },
        {
          "t": "Crit 2d6+4",
          "c": "ember"
        },
        {
          "t": "Vex",
          "c": "storm"
        }
      ],
      "body": [
        "Your melee sidearm. Finesse lets you use Dexterity for attack and damage, so +5 to hit (Dex +3, proficiency +2) and 1d6+3.",
        "Vex (mastery): when you hit and deal damage, you have Advantage on your next attack roll against that target, until the end of your next turn."
      ]
    },
    "dreadful": {
      "title": "Dreadful Strikes",
      "dice": "+1d4 psychic",
      "chips": [
        {
          "t": "Once per target / turn",
          "c": "ember"
        },
        {
          "t": "No action"
        }
      ],
      "body": [
        "Once per turn, when you hit a creature with a weapon, you can deal an extra 1d4 psychic damage. Each creature can take this extra damage only once per turn.",
        "It costs no action and stacks with Hunter's Mark; the die grows to 1d6 at ranger level 11.",
        "It isn't magical and needs no Concentration — it simply rides your hits."
      ]
    },
    "asi": {
      "title": "Level 4 — Ability Score Improvement",
      "dice": null,
      "chips": [
        {
          "t": "Taken as a feat",
          "c": "ember"
        }
      ],
      "body": [
        "At level 4 the Ability Score Improvement was taken as a feat (Lucky) rather than a +2/+1+1 to ability scores, so your scores stay at the base array plus the Guide background's +2 Dexterity / +1 Wisdom.",
        "If you'd rather have the boost, swap this for +2 Dexterity (raising it to 19): +1 to your attack and damage, AC, Initiative, and Dexterity saves."
      ]
    },
    "favoredenemy": {
      "title": "Favored Enemy",
      "dice": null,
      "chips": [
        {
          "t": "Hunter's Mark",
          "c": "storm"
        },
        {
          "t": "Free 2×/long rest",
          "c": "ember"
        }
      ],
      "body": [
        "You always have Hunter's Mark prepared, and you can cast it without a spell slot a number of times equal to your Proficiency Bonus (2) per long rest. After that, cast it with a slot.",
        "This is your signature damage rider — turn it on as a Bonus Action at the start of a fight."
      ]
    },
    "archery": {
      "title": "Fighting Style: Archery",
      "dice": null,
      "chips": [
        {
          "t": "+2 ranged attacks",
          "c": "ember"
        }
      ],
      "body": [
        "You gain a +2 bonus to attack rolls with ranged weapons. Already included in the longbow's +7 to hit."
      ]
    },
    "deftexplorer": {
      "title": "Deft Explorer",
      "dice": null,
      "chips": [
        {
          "t": "Expertise (Insight)",
          "c": "ember"
        },
        {
          "t": "+2 languages",
          "c": "storm"
        }
      ],
      "body": [
        "You gain Expertise in one skill — taken in Insight, doubling your Proficiency Bonus there (Insight +6). You also learn two additional languages (Common plus Dwarvish, Elvish, Goblin, and Undercommon).",
        "Move the Expertise onto another proficient skill if your table prefers."
      ]
    },
    "glamour": {
      "title": "Otherworldly Glamour",
      "dice": null,
      "chips": [
        {
          "t": "+Wis to Cha checks",
          "c": "ember"
        },
        {
          "t": "Persuasion",
          "c": "storm"
        }
      ],
      "body": [
        "Whenever you make a Charisma check, add your Wisdom modifier (minimum +1) — here +2. You also gain proficiency in one of Deception, Performance, or Persuasion — taken in Persuasion.",
        "This makes a Charisma-12 ranger a strong talker: Persuasion is +5 (Cha +1, prof +2, glamour +2)."
      ]
    },
    "bootsofelvenkind": {
      "title": "Boots of Elvenkind",
      "chips": [
        {
          "t": "Wondrous item"
        },
        {
          "t": "No attunement",
          "c": "storm"
        },
        {
          "t": "Stealth",
          "c": "ember"
        }
      ],
      "body": [
        "While you wear these boots, your steps make no sound, regardless of the surface you move across.",
        "You also have Advantage on any Dexterity (Stealth) check you make that relies on moving silently."
      ]
    }
  },
